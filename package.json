{
    "name": "vsxtools",
    "version": "0.0.1",
    "description": "Developer tools for building VSCode extensions",
    "homepage": "https://github.com/ProCode-Software/vsxtools",
    "repository": {
        "type": "git",
        "url": "https://github.com/ProCode-Software/vsxtools.git"
    },
    "bugs": {
        "url": "https://github.com/ProCode-Software/vsxtools/issues"
    },
    "keywords": [
        "cli",
        "vscode",
        "vscode-theme",
        "vscode-extension"
    ],
    "license": "MIT",
    "author": "ProCode Software",
    "bin": {
        "vsxtools": "dist/cli/vsxtools.js"
    },
    "files": [
        "dist",
        "assets",
        "types"
    ],
    "type": "module",
    "main": "dist/cli/vsxtools.js",
    "exports": {
        ".": {
            "types": "./dist/lib/vsxtools/vsxtools.d.ts",
            "default": "./dist/lib/vsxtools/vsxtools.js"
        },
        "./*": {
            "types": "./dist/lib/*/*.d.ts",
            "default": "./dist/lib/*/*.js"
        }
    },
    "scripts": {
        "build": "bun tsgo",
        "start": "bun run ./src/cli/vsxtools.ts",
        "dev": "bun tsgo --watch"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.4.2",
        "commander": "^14.0.3"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "latest",
        "@vscode/codicons": "latest"
    },
    "optionalDependencies": {
        "@vscode/codicons": "^0.0.45",
        "@vscode/vsce": "^3.9.1"
    },
    "packageManager": "bun@1.3.13"
}
