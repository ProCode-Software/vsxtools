{
    "name": "vsxtools",
    "version": "0.0.2",
    "description": "Developer tools for building VSCode extensions",
    "type": "module",
    "main": "dist/lib/vsxtools/vsxtools.js",
    "scripts": {
        "build": "bun run ./scripts/syncVendored.ts && bun tsgo",
        "start": "bun run ./src/cli/vsxtools.ts",
        "vsxtools": "bun run ./src/cli/vsxtools.ts",
        "dev": "bun tsgo --watch",
        "check": "bun tsgo --noEmit"
    },
    "license": "MIT",
    "author": "ProCode Software",
    "bin": {
        "vsxtools": "dist/cli/vsxtools.js"
    },
    "files": [
        "dist",
        "assets",
        "types"
    ],
    "exports": {
        ".": {
            "types": "./dist/lib/vsxtools/vsxtools.d.ts",
            "default": "./dist/lib/vsxtools/vsxtools.js"
        },
        "./*": {
            "types": "./dist/lib/*/*.d.ts",
            "default": "./dist/lib/*/*.js"
        }
    },
    "imports": {
        "#lib/*.ts": "./src/lib/*.ts",
        "#lib/*.js": "./dist/lib/*.js",
        "#/*.ts": "./src/*.ts",
        "#/*.js": "./dist/*.js"
    },
    "homepage": "https://github.com/ProCode-Software/vsxtools",
    "repository": {
        "type": "git",
        "url": "https://github.com/ProCode-Software/vsxtools.git"
    },
    "bugs": {
        "url": "https://github.com/ProCode-Software/vsxtools/issues"
    },
    "keywords": [
        "cli",
        "vscode",
        "vscode-theme",
        "vscode-extension"
    ],
    "dependencies": {
        "@inquirer/prompts": "^8.4.3",
        "adm-zip": "^0.5.17",
        "commander": "^14.0.3"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.8",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.8.0",
        "@typescript/native-preview": "latest",
        "@vscode/codicons": "latest"
    },
    "optionalDependencies": {
        "@vscode/codicons": "^0.0.45"
    },
    "packageManager": "bun@1.3.13"
}
